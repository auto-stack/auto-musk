// specs_test.at - Spec 数据模型层测试（AutoVM 运行）
// 验收：SectionType/SpecStatus 的 to_str/from_str 往返、SpecItem/SpecsDocument 工厂、tags 字段。
// 用模块级函数（AutoVM enum 方法 bug 的绕过）。
// 运行：auto src/back/specs_test.at

use specs

pub fn check(label str, actual str, expected str) {
    if actual == expected {
        print("[PASS] " + label)
    } else {
        print("[FAIL] " + label + ": expected " + expected + ", got " + actual)
    }
}

pub fn main() {
    print("=== SectionType ===")
    check("Goals.as_str", section_type_as_str(SectionType.Goals), "goals")
    check("Reports.as_str", section_type_as_str(SectionType.Reports), "reports")
    check("Goals.display_title", section_type_display_title(SectionType.Goals), "🎯 Goals")
    check("from_id goals", section_type_as_str(section_type_from_id("goals")), "goals")
    check("from_id unknown->Goals", section_type_as_str(section_type_from_id("xxx")), "goals")

    print("")
    print("=== SpecStatus to_str ===")
    check("Empty.to_str", status_to_str(SpecStatus.Empty), "empty")
    check("InProgress.to_str", status_to_str(SpecStatus.InProgress), "in_progress")
    check("UnderReview.to_str", status_to_str(SpecStatus.UnderReview), "under_review")

    print("")
    print("=== SpecStatus from_str 往返 ===")
    check("roundtrip approved", status_to_str(status_from_str("approved")), "approved")
    check("roundtrip verified", status_to_str(status_from_str("verified")), "verified")
    check("roundtrip unknown->Draft", status_to_str(status_from_str("nonsense")), "draft")

    print("")
    print("=== SpecItem 工厂 + tags ===")
    let item = new_spec_item("G1", "First goal")
    check("item.id", item.id, "G1")
    check("item.title", item.title, "First goal")
    check("item.status default Empty", status_to_str(item.status), "empty")
    check("item.depends_on empty", item.depends_on.len(), "0")
    check("item.related empty", item.related.len(), "0")
    check("item.tags empty (auto-coder missed this)", item.tags.len(), "0")

    item.tags = ["backend", "auth"]
    item.depends_on = ["A1"]
    check("item.tags set", item.tags.len(), "2")
    check("item.depends_on set", item.depends_on.len(), "1")

    print("")
    print("=== SpecsDocument 工厂（7 section） ===")
    let doc = new_specs_document("test-project")
    check("doc.project", doc.project, "test-project")
    check("doc.version initial", doc.version, "0")
    check("doc.sections len == 7", doc.sections.len(), "7")
    check("section[0] type Goals", section_type_as_str(doc.sections[0].section_type), "goals")
    check("section[6] type Reports", section_type_as_str(doc.sections[6].section_type), "reports")
    check("section[0] title emoji", doc.sections[0].title, "🎯 Goals")

    print("")
    print("=== SpecItem 加入 section ===")
    doc.sections[0].items = [item]
    check("goals has 1 item", doc.sections[0].items.len(), "1")
    check("that item is G1", doc.sections[0].items[0].id, "G1")

    print("")
    print("=== Done ===")
}
