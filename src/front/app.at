// src/front/app.at - auto-musk 根 widget
// App Shell: 路由 + 左侧导航 rail + outlet。
// 参照 auto-forge 的 9-tab 布局（frontend/src/App.vue:134）。
// DSL 风格沿用 015-notes 已验证写法（row/col/link/button），不依赖未验证的内置组件。

widget App {
    routes {
        "/" -> use login
        "/explorer" -> use explorer
        "/chats" -> use chats
        "/specs" -> use specs
        "/relay" -> use relay
    }

    view {
        outlet
    }
}
